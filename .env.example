# @manualReviewRequested: 2026-07-06
# Copy this file to ".env" and fill in real values. ".env" is gitignored and must never be committed.
# See source/backend/core/config/settings.py for the authoritative, documented list of every setting.

# Signs session cookies. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# The single local user's login name.
ADMIN_USERNAME=admin

# werkzeug password hash for login. Generate with:
# python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('your-password'))"
ADMIN_PASSWORD_HASH=

# Optional plaintext password accepted as an alternate login, so you don't need to regenerate
# ADMIN_PASSWORD_HASH every time you want to change it locally. Only honored while FLASK_DEBUG=1 —
# never set this in a non-debug run. Requires FLASK_DEBUG=1 below to also be set explicitly; it's
# opt-in twice over so a fresh checkout never has a weaker login path by accident.
ADMIN_PASSWORD_DEV_OVERRIDE=

# Filesystem root the database writes record files under.
DATA_ROOT=./data

# Enables Flask debug mode and the auto-reloader, and gates ADMIN_PASSWORD_DEV_OVERRIDE above.
# Off by default — only turn this on for local development.
FLASK_DEBUG=0

# How long a login session stays valid, in minutes. Defaults to 12 hours, so a session survives a
# single day's use but requires signing in again the next day.
SESSION_LIFETIME_MINUTES=720

# Port the Flask dev server listens on.
BACKEND_PORT=5000

# Origin allowed by CORS in development (the Vite dev server).
FRONTEND_ORIGIN=http://localhost:5173
